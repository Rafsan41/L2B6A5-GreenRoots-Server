{
  "name": "prisma-next-medistore-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Your Trusted Online Medecine Shop",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsup -p tsc node fix-imports.js",
    "vercel-build": "prisma generate && tsup src/index.ts --format esm --platform node --target node20 --outDir api --external pg-native",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "seed:medicines": "tsx src/scripts/seedMedicines.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/nodemailer": "^8.0.0",
    "better-auth": "^1.6.9",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "sslcommerz-lts": "^1.2.0",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
